# ─── NextHire AI — Environment Variables ───────────────────────────────────────
# Copy this to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas (free tier) – https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT — access token (short-lived)
JWT_SECRET=change_this_to_a_very_long_random_string_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m

# JWT — refresh token (long-lived, separate secret)
JWT_REFRESH_SECRET=another_very_long_random_secret_different_from_jwt_secret
JWT_REFRESH_EXPIRES=7d

# Groq LLM (free tier) – https://console.groq.com
# Used for: resume screening, coding questions, interview questions, code evaluation
GROQ_API_KEY=gsk_your_groq_api_key_here
# Override the default AI model (optional — defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudinary — file storage (free: 25GB storage + 25GB bandwidth/month)
# Sign up at https://cloudinary.com → Dashboard → copy Cloud Name, API Key, API Secret
# Leave ALL THREE blank to use local file storage fallback (files saved to server/uploads/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Judge0 via RapidAPI (free 50 req/day) – https://rapidapi.com/judge0-official/api/judge0-ce
# Leave blank → falls back to Node.js vm sandbox (JS only)
# With key → supports Python, Java, C++, Go, Rust, and 10+ languages
JUDGE0_API_KEY=
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
