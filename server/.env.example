# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas free tier → https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/nexthire

# ── Auth (JWT) ────────────────────────────────────────────────────────────
# Access token — short-lived (15 minutes)
JWT_SECRET=change_this_to_long_random_min_64_chars_in_production
JWT_ACCESS_EXPIRES=15m

# Refresh token — long-lived (7 days), different secret for security
JWT_REFRESH_SECRET=different_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES=7d

# ── AI / LLM ─────────────────────────────────────────────────────────────
# Groq (free) → https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinecone Vector DB (free) → https://app.pinecone.io
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_INDEX=nexthire-resumes

# ── Code Execution — Judge0 CE via RapidAPI (REQUIRED) ───────────────────────
# Judge0 is used for all code execution (run + submit).
# Sign up free: https://rapidapi.com/judge0-official/api/judge0-ce
# Free plan: 50 submissions/day  |  Docs: https://judge0.com
# Steps: Subscribe → "X-RapidAPI-Key" header value → paste below
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here

# ── AWS (optional — for S3 resume storage) ────────────────────────────────
# Create free-tier AWS account → IAM → User with S3 permissions
# S3 → Create bucket (e.g. nexthire-resumes-prod)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexthire-resumes-prod

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
